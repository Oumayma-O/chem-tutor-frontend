# FastAPI backend
# Production / direct-to-API (browser must hit same host or backend must send CORS headers):
#   VITE_API_URL=https://your-api.example.com/api/v1
# Local dev without CORS errors (Vite proxies /api → http://127.0.0.1:8000 — see vite.config.ts):
#   VITE_API_URL=/api/v1
# Local dev calling API directly (backend must allow Origin http://localhost:8080):
#   VITE_API_URL=http://localhost:8000/api/v1

# Tutor: fallback max answer reveals per lesson if the API omits `max_answer_reveals_per_lesson`
# (server should send it on problem delivery + live-session). Default 6 if unset.
VITE_TUTOR_MAX_ANSWER_REVEALS_PER_LESSON=6
# Tutor: min Level 1 worked examples before Level 2 unlocks. Default 2 if unset.
VITE_TUTOR_MIN_LEVEL1_EXAMPLES_FOR_LEVEL2=2
